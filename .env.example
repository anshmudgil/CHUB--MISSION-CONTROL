# Anthropic API Key — required for Council AI streaming and OpenCore autonomous workflows
# Get yours at https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# App URL — used by ACP client for server-to-server calls
# In production, Railway sets this to your public domain
# Locally: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# For Hermes agent (separate Railway service)
# Set this to your deployed Mission Control URL
MISSION_CONTROL_URL=https://your-mission-control.railway.app
